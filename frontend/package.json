{
  "name": "jarvis-prime-orb",
  "version": "1.0.0",
  "type": "module",
  "main": "./main.cjs",
  "scripts": {
    "start": "npm run build && electron .",
    "start:electron": "electron .",
    "dev": "vite",
    "build": "vite build",
    "dist": "electron-builder"
  },
  "dependencies": {
    "three": "^0.160.0"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.0"
  },
  "build": {
    "appId": "com.stark.jarvis",
    "productName": "JARVIS Prime",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/sounds",
        "to": "sounds",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon-jarvis.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "description": "J.A.R.V.I.S. Prime — AI Assistant",
  "author": "Amine"
}
